{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "feiq-plus-plus",
  "version": "0.1.0",
  "identifier": "com.feiq-plus-plus.app",
  "build": {
    "frontendDist": "../feiq-gui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../feiq-gui && npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "feiq++",
        "width": 860,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
